# Frontend
BACKEND_INTERNAL_URL=http://127.0.0.1:8081

# Backend runtime
BACKEND_PORT=8081
SPRING_PROFILES_ACTIVE=dev

# Database
DB_URL=jdbc:postgresql://localhost:5432/eungeum
DB_USERNAME=eungeum
DB_PASSWORD=change-me
DB_DRIVER=org.postgresql.Driver

# Public app URL
AUTH_PUBLIC_BASE_URL=https://your-domain.example
AUTH_ALLOWED_ORIGINS=https://your-domain.example,http://localhost:3000

# Session / auth
AUTH_SESSION_COOKIE_NAME=EG_SESSION
AUTH_SESSION_TTL=PT336H
AUTH_OAUTH_STATE_TTL=PT10M
AUTH_COOKIE_SECURE=true
AUTH_REQUIRED_TERMS_VERSION=2026-04-04

# Naver OAuth
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret
NAVER_AUTHORIZATION_URI=https://nid.naver.com/oauth2.0/authorize
NAVER_TOKEN_URI=https://nid.naver.com/oauth2.0/token
NAVER_USER_INFO_URI=https://openapi.naver.com/v1/nid/me

# Kakao OAuth
KAKAO_CLIENT_ID=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=
KAKAO_AUTHORIZATION_URI=https://kauth.kakao.com/oauth/authorize
KAKAO_TOKEN_URI=https://kauth.kakao.com/oauth/token
KAKAO_USER_INFO_URI=https://kapi.kakao.com/v2/user/me
